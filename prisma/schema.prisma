generator client {
  provider = "prisma-client-js"
  output   = "./generated-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  phone         String?        @unique
  password      String?
  role          String         @default("Admin")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  about         String?
  designation   String?
  image         String?
  socials       Json?
  employeeId    String?        @unique
  notifications Notification[]
  posts         Post[]
}

model Post {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  excerpt       String
  content       String
  image         String?
  category      String
  readTime      String
  published     Boolean   @default(false)
  date          DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  dislikes      Int       @default(0)
  likes         Int       @default(0)
  tags          String[]  @default([])
  authorId      String?
  reviewComment String?
  status        String    @default("DRAFT")
  thumbnail     String?
  comments      Comment[]
  author        User?     @relation(fields: [authorId], references: [id])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  author    String
  content   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model BlogCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id           String           @id @default(cuid())
  title        String
  tag          String
  description  String
  active       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  about        String?
  location     String           @default("Remote / Hybrid")
  sections     Json?
  slug         String           @unique @default(cuid())
  type         String           @default("Full-Time")
  howToApply   String?
  applications JobApplication[]
}

model JobApplication {
  id             String   @id @default(cuid())
  jobId          String?
  fullName       String
  email          String
  phone          String?
  resumeUrl      String
  coverLetter    String?
  additionalInfo String?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  position       String?
  job            Job?     @relation(fields: [jobId], references: [id])
  
  // New applicant fields
  isStudent      Boolean? @default(false)
  currentCompany String?
  experienceYear String?
  yearOfStudy    String?
  department     String?
  course         String?
  referredRole   String?
  interviewStatus String  @default("NOT_SCHEDULED")
  statusRemark    String?
}

model ContactInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
}

model LaunchpadApplication {
  id           String   @id @default(cuid())
  fullName     String
  email        String
  description  String
  status       String   @default("NEW")
  createdAt    DateTime @default(now())
  category     String?
  mobileNumber String?
  startupName  String
}

model Service {
  id               String   @id @default(cuid())
  slug             String   @unique
  title            String
  shortDescription String
  fullDescription  String
  image            String?
  features         Json?
  benefits         String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  image     String?
  bio       String?
  socials   Json?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expert {
  id           String        @id @default(cuid())
  name         String
  role         String
  image        String?
  bio          String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model Appointment {
  id          String   @id @default(cuid())
  expertId    String
  clientName  String
  clientEmail String
  clientPhone String?
  date        DateTime
  reason      String?
  status      String   @default("CONFIRMED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expert      Expert   @relation(fields: [expertId], references: [id])
}

model NewsletterSubscriber {
  id        String                  @id @default(cuid())
  email     String                  @unique
  status    String                  @default("ACTIVE")
  createdAt DateTime                @default(now())
  name      String?
  groups    NewsletterGroupMember[]
}

model NewsletterGroup {
  id          String                  @id @default(cuid())
  name        String                  @unique
  description String?
  color       String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  members     NewsletterGroupMember[]
  newsletters NewsletterTargetGroup[]
}

model NewsletterGroupMember {
  groupId      String
  subscriberId String
  createdAt    DateTime             @default(now())
  group        NewsletterGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subscriber   NewsletterSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@id([groupId, subscriberId])
}

model Newsletter {
  id             String                  @id @default(cuid())
  title          String
  subject        String
  preheader      String?
  content        String
  status         String                  @default("DRAFT")
  sendToAll      Boolean                 @default(false)
  sentAt         DateTime?
  recipientCount Int                     @default(0)
  successCount   Int                     @default(0)
  failureCount   Int                     @default(0)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  targetGroups   NewsletterTargetGroup[]
}

model NewsletterTargetGroup {
  newsletterId String
  groupId      String
  group        NewsletterGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  newsletter   Newsletter      @relation(fields: [newsletterId], references: [id], onDelete: Cascade)

  @@id([newsletterId, groupId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailTemplate {
  id          String             @id @default(cuid())
  name        String             @unique
  subject     String
  body        String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  description String?
  isActive    Boolean            @default(true)
  mappings    FormEmailMapping[]
}

model FormEmailMapping {
  id         String        @id @default(cuid())
  formKey    String        @unique
  templateId String
  enabled    Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  template   EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model EmailLog {
  id         String   @id @default(cuid())
  formKey    String
  templateId String?
  to         String
  subject    String
  status     String
  error      String?
  messageId  String?
  createdAt  DateTime @default(now())
}
